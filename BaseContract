pragma solidity ^0.8.0;

/**
 * @title BaseContract
 * @dev The "Parent" contract containing shared rules for all organizations.
 */
contract BaseContract {
    string public organizationName;

    /**
     * @notice Sets the name of the organization with a safety check.
     * @param _name The name to be assigned.
     */
    function setOrganizationName(string memory _name) public {
        // Task 1: Validation to ensure the name isn't just an empty space
        require(bytes(_name).length > 0, "Name cannot be empty");
        organizationName = _name;
    }
}

/**
 * @title DerivedContract
 * @dev The "Child" contract that inherits from BaseContract.
 * It "is" a BaseContract, but with extra funding powers.
 */
contract DerivedContract is BaseContract {
    uint256 public fundBalance;

    /**
     * @notice Adds funds to the balance with a safety check.
     * @param _amount The value to be deposited.
     */
    function depositFunds(uint256 _amount) public {
        // Task 2: Ensure the deposit actually has value
        require(_amount > 0, "Amount must be greater than zero");
        fundBalance += _amount;
    }
}
